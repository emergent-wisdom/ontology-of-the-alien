{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "condition", "run", "solution", "timestamp"],
  "properties": {
    "id": {
      "type": "string",
      "description": "{condition}_{run:02d}"
    },
    "condition": {
      "type": "string",
      "enum": ["denial", "protocol", "combined"]
    },
    "run": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "seed": {
      "type": ["string", "null"],
      "description": "Seed word (null for denial)"
    },
    "world": {
      "type": ["string", "null"],
      "description": "World Builder output as free-form text (null for denial)"
    },
    "solver": {
      "type": ["string", "null"],
      "description": "Solver output as free-form text (null for denial)"
    },
    "solution": {
      "type": "object",
      "properties": {
        "label": { "type": "string", "maxLength": 40 },
        "design_principles": { "type": "string", "maxLength": 200 },
        "core_mechanism": { "type": "string", "maxLength": 200 },
        "how_it_works": { "type": "string", "maxLength": 500 },
        "what_is_new": { "type": "string", "maxLength": 200 },
        "medium_term": { "type": "string", "maxLength": 200 },
        "long_term_vision": { "type": "string", "maxLength": 300 }
      },
      "required": ["label", "design_principles", "core_mechanism", "how_it_works", "what_is_new", "medium_term", "long_term_vision"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
